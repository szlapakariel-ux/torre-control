# Copiá este archivo a .env (o cargá estas variables en el host) y completá los valores.

# Puerto en el que escucha el backend. Muchos hosts (Railway, Render) lo inyectan solos.
PORT=3001

# Orígenes permitidos para CORS, separados por coma (sin barra final).
# Ej. producción: https://szlapakariel-ux.github.io
ALLOWED_ORIGIN=http://localhost:3001,http://localhost:5173

# Token secreto para los endpoints de escritura (POST/PATCH).
# Generá uno largo y aleatorio. Sin esta variable, la escritura queda deshabilitada.
API_TOKEN=

# Directorio donde se guarda la base SQLite. En producción apuntá a un volumen persistente.
DATA_DIR=./data

# Clave de la API de Anthropic para el cerebro de IA de la Torre.
# OPCIONAL: sin esta variable, la Torre clasifica con el motor local por palabras
# clave (degradación elegante, no rompe nada). Con ella, usa Claude.
# Nota: claude-fable-5 requiere una org con retención de datos de 30 días.
ANTHROPIC_API_KEY=

# Modelo de Claude a usar para clasificar y responder. OPCIONAL (default: claude-haiku-4-5).
# Opciones recomendadas, de más barato a más potente:
#   claude-haiku-4-5   → rápido y barato, ideal para mensajes cortos (default)
#   claude-sonnet-4-6  → balance calidad/costo
#   claude-fable-5     → máxima comprensión, el más caro
TORRE_MODEL=claude-haiku-4-5

# API de ElevenLabs para síntesis de voz tipo JARVIS.
# Requeridas para el endpoint POST /api/voz y GET /api/voz/status.
# Obtené tu API key en https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# ID de la voz a usar en ElevenLabs.
# Podés encontrar los IDs en https://elevenlabs.io/app/voice-library
# Ejemplo de voz masculina profunda (tipo JARVIS): usar el ID de la voz elegida
ELEVENLABS_VOICE_ID=

# Modelo de ElevenLabs. OPCIONAL (default: eleven_multilingual_v2)
# Opciones: eleven_multilingual_v2, eleven_monolingual_v1, eleven_turbo_v2
ELEVENLABS_MODEL=eleven_multilingual_v2
